// Prisma schema — mirrors PHP project MySQL schema exactly
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        Int       @id @default(autoincrement())
  username  String    @unique @db.VarChar(50)
  password  String    @db.VarChar(255)
  fullName  String    @map("full_name") @db.VarChar(100)
  email     String?   @db.VarChar(100)
  role      AdminRole @default(admin)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  lastLogin DateTime? @map("last_login")

  @@map("admin_users")
}

enum AdminRole {
  superadmin
  super_admin
  admin
  staff
  editor
}

model Member {
  id                 Int       @id @default(autoincrement())
  name               String    @db.VarChar(255)
  email              String?   @unique @db.VarChar(255)
  phone              String?   @db.VarChar(20)
  sadasyataNumber    String    @default("") @map("sadasyata_number") @db.VarChar(50)
  passwordHash       String?   @map("password_hash") @db.VarChar(255)
  googleId           String?   @map("google_id") @db.VarChar(255)
  avatarUrl          String?   @map("avatar_url") @db.VarChar(500)
  memberCardNo       String?   @map("member_card_no") @db.VarChar(50)
  address            String?   @db.Text
  dob                DateTime? @db.Date
  gender             String?   @db.VarChar(20)
  approvalStatus     String    @default("pending") @map("approval_status") @db.VarChar(20)
  approvedAt         DateTime? @map("approved_at")
  approvedBy         Int?      @map("approved_by")
  rejectionReason    String?   @map("rejection_reason") @db.Text
  idCardGenerated    Boolean   @default(false) @map("id_card_generated")
  idCardGeneratedAt  DateTime? @map("id_card_generated_at")
  isVerified         Boolean   @default(false) @map("is_verified")
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  lastLogin          DateTime? @map("last_login")

  loanApplications   LoanApplication[]
  kycApplications    KycApplication[]
  grievances         Grievance[]

  @@map("members")
}

model SiteSetting {
  id           Int          @id @default(autoincrement())
  settingKey   String       @unique @map("setting_key") @db.VarChar(100)
  settingValue String?      @map("setting_value") @db.Text
  settingType  SettingType  @default(text) @map("setting_type")
  settingLabel String?      @map("setting_label") @db.VarChar(200)
  settingGroup String       @default("general") @map("setting_group") @db.VarChar(50)
  updatedAt    DateTime?    @updatedAt @map("updated_at")

  @@map("site_settings")
}

enum SettingType {
  text
  textarea
  image
  number
  color
  url
}

model Notice {
  id         Int       @id @default(autoincrement())
  title      String    @db.VarChar(255)
  titleNp    String?   @map("title_np") @db.VarChar(255)
  content    String?   @db.Text
  contentNp  String?   @map("content_np") @db.Text
  noticeDate DateTime? @map("notice_date") @db.Date
  attachment String?   @db.VarChar(255)
  isActive   Boolean   @default(true) @map("is_active")
  isPopup    Boolean   @default(false) @map("is_popup")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  @@map("notices")
}

model InterestRate {
  id            Int              @id @default(autoincrement())
  category      InterestCategory
  name          String           @db.VarChar(100)
  nameNp        String?          @map("name_np") @db.VarChar(100)
  rate          Decimal          @db.Decimal(5, 2)
  description   String?          @db.Text
  descriptionNp String?          @map("description_np") @db.Text
  isActive      Boolean          @default(true) @map("is_active")
  displayOrder  Int              @default(0) @map("display_order")
  updatedAt     DateTime?        @updatedAt @map("updated_at")

  @@map("interest_rates")
}

enum InterestCategory {
  saving
  loan
}

model Service {
  id            Int       @id @default(autoincrement())
  title         String    @db.VarChar(100)
  titleNp       String?   @map("title_np") @db.VarChar(100)
  titleEn       String?   @map("title_en") @db.VarChar(100)
  description   String?   @db.Text
  descriptionNp String?   @map("description_np") @db.Text
  icon          String    @default("star") @db.VarChar(50)
  image         String?   @db.VarChar(255)
  isActive      Boolean   @default(true) @map("is_active")
  displayOrder  Int       @default(0) @map("display_order")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("services")
}

model Slider {
  id           Int      @id @default(autoincrement())
  title        String?  @db.VarChar(200)
  subtitle     String?  @db.VarChar(255)
  image        String   @db.VarChar(255)
  buttonText   String?  @map("button_text") @db.VarChar(50)
  buttonUrl    String?  @map("button_url") @db.VarChar(255)
  isActive     Boolean  @default(true) @map("is_active")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("sliders")
}

model Gallery {
  id           Int      @id @default(autoincrement())
  title        String?  @db.VarChar(200)
  titleNp      String?  @map("title_np") @db.VarChar(200)
  image        String   @db.VarChar(255)
  category     String   @default("general") @db.VarChar(50)
  isActive     Boolean  @default(true) @map("is_active")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("gallery")
}

model TeamMember {
  id                  Int            @id @default(autoincrement())
  name                String         @db.VarChar(100)
  nameEn              String?        @map("name_en") @db.VarChar(100)
  position            String?        @db.VarChar(100)
  positionNp          String?        @map("position_np") @db.VarChar(100)
  positionEn          String?        @map("position_en") @db.VarChar(100)
  photo               String?        @db.VarChar(255)
  phone               String?        @db.VarChar(20)
  email               String?        @db.VarChar(100)
  category            TeamCategory   @default(staff)
  isInformationOfficer Boolean       @default(false) @map("is_information_officer")
  isGrievanceOfficer  Boolean        @default(false) @map("is_grievance_officer")
  isActive            Boolean        @default(true) @map("is_active")
  displayOrder        Int            @default(0) @map("display_order")
  createdAt           DateTime       @default(now()) @map("created_at")

  @@map("team_members")
}

enum TeamCategory {
  board
  management
  staff
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  email     String?  @db.VarChar(100)
  phone     String?  @db.VarChar(20)
  subject   String?  @db.VarChar(200)
  message   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

model News {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(255)
  titleNp     String?   @map("title_np") @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)
  content     String?   @db.LongText
  contentNp   String?   @map("content_np") @db.LongText
  image       String?   @db.VarChar(255)
  category    String    @default("general") @db.VarChar(50)
  isActive    Boolean   @default(true) @map("is_active")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  @@map("news")
}

model Faq {
  id           Int      @id @default(autoincrement())
  question     String   @db.Text
  questionNp   String?  @map("question_np") @db.Text
  answer       String   @db.Text
  answerNp     String?  @map("answer_np") @db.Text
  category     String   @default("general") @db.VarChar(50)
  isActive     Boolean  @default(true) @map("is_active")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("faqs")
}

model LoanApplication {
  id             Int      @id @default(autoincrement())
  trackingId     String   @unique @map("tracking_id") @db.VarChar(20)
  memberId       Int?     @map("member_id")
  fullName       String   @map("full_name") @db.VarChar(255)
  phone          String   @db.VarChar(20)
  email          String?  @db.VarChar(100)
  loanType       String   @map("loan_type") @db.VarChar(100)
  loanAmount     Decimal  @map("loan_amount") @db.Decimal(12, 2)
  loanPurpose    String?  @map("loan_purpose") @db.Text
  status         String   @default("pending") @db.VarChar(20)
  remarks        String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime? @updatedAt @map("updated_at")

  member         Member?  @relation(fields: [memberId], references: [id])

  @@map("loan_applications")
}

model KycApplication {
  id          Int      @id @default(autoincrement())
  trackingId  String   @unique @map("tracking_id") @db.VarChar(20)
  memberId    Int?     @map("member_id")
  fullName    String   @map("full_name") @db.VarChar(255)
  phone       String   @db.VarChar(20)
  email       String?  @db.VarChar(100)
  status      String   @default("pending") @db.VarChar(20)
  remarks     String?  @db.Text
  formData    String?  @map("form_data") @db.LongText
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  member      Member?  @relation(fields: [memberId], references: [id])

  @@map("kyc_applications")
}

model Grievance {
  id          Int      @id @default(autoincrement())
  trackingId  String   @unique @map("tracking_id") @db.VarChar(20)
  memberId    Int?     @map("member_id")
  name        String   @db.VarChar(255)
  phone       String?  @db.VarChar(20)
  email       String?  @db.VarChar(100)
  subject     String   @db.VarChar(255)
  description String   @db.Text
  status      String   @default("pending") @db.VarChar(20)
  remarks     String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  member      Member?  @relation(fields: [memberId], references: [id])

  @@map("grievances")
}

model Career {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(255)
  titleNp     String?   @map("title_np") @db.VarChar(255)
  department  String?   @db.VarChar(100)
  location    String?   @db.VarChar(100)
  jobType     String    @default("full-time") @map("job_type") @db.VarChar(50)
  description String?   @db.LongText
  requirements String?  @db.Text
  salary      String?   @db.VarChar(100)
  deadline    DateTime? @db.Date
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("careers")
}

model Download {
  id           Int      @id @default(autoincrement())
  title        String   @db.VarChar(255)
  titleNp      String?  @map("title_np") @db.VarChar(255)
  file         String   @db.VarChar(255)
  category     String   @default("general") @db.VarChar(50)
  isActive     Boolean  @default(true) @map("is_active")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("downloads")
}

model ServiceCenter {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  nameNp      String?  @map("name_np") @db.VarChar(255)
  address     String?  @db.Text
  phone       String?  @db.VarChar(50)
  email       String?  @db.VarChar(100)
  mapUrl      String?  @map("map_url") @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  displayOrder Int     @default(0) @map("display_order")

  @@map("service_centers")
}
